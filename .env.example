# HTTP trigger protection. Set this before exposing /jobs/process-mail.
WORKER_SHARED_SECRET=

# Microsoft Graph app-only auth.
GRAPH_TENANT_ID=
GRAPH_CLIENT_ID=
GRAPH_CLIENT_SECRET=
GRAPH_MAILBOX=
GRAPH_SOURCE_FOLDER=Inbox
GRAPH_PROCESSED_FOLDER=Processed
GRAPH_MANUAL_FOLDER=Manual
GRAPH_ERROR_FOLDER=Error
GRAPH_MAX_MESSAGES=10
GRAPH_SUBJECT_KEYWORDS=e-Fatura,e-Arsiv,Fatura
MAIL_POLLER_ENABLED=true
MAIL_POLL_INTERVAL_SECONDS=300
APP_SETTINGS_PATH=data/runtime_settings.json
APP_LOG_PATH=data/activity_log.jsonl

# Mail provider switch for future extensions.
# Current runtime implementation supports microsoft.
MAIL_PROVIDER=microsoft

# Google Workspace/Gmail future connector placeholders.
GOOGLE_WORKSPACE_DOMAIN=
GOOGLE_SERVICE_ACCOUNT_JSON_PATH=
GOOGLE_IMPERSONATED_USER=
GOOGLE_SOURCE_LABEL=INBOX
GOOGLE_PROCESSED_LABEL=Processed
GOOGLE_MANUAL_LABEL=Manual
GOOGLE_ERROR_LABEL=Error
GOOGLE_SUBJECT_KEYWORDS=e-Fatura,e-Arsiv,Fatura

# Keep dry-run until SAP payload mapping is approved.
SAP_MODE=dry-run
SAP_MAPPING_PATH=config/sap_mapping.json
SAP_MAPPING_JSON=
SAP_POSTING_USER=

# SAP placeholders for the next slice.
SAP_BASE_URL=
SAP_AUTH_URL=
SAP_CLIENT_ID=
SAP_CLIENT_SECRET=
SAP_COMPANY_CODE=
